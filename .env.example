# ──────────────────────────────────────────────
# ระบบรับ-ส่งจดหมายพัสดุ และการควบคุมเอกสาร
# Environment Variables (Example)
# ──────────────────────────────────────────────

# Supabase (Vercel Marketplace)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Sheets API (Service Account)
GOOGLE_SHEETS_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Google Drive API (Service Account)
GOOGLE_DRIVE_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Super Admin (first user)
SUPER_ADMIN_EMAIL=store-hk@hillkoff.com