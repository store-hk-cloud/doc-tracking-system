# ──────────────────────────────────────────────
# ระบบรับ-ส่งจดหมายพัสดุ และการควบคุมเอกสาร
# Environment Variables
# ──────────────────────────────────────────────
# Vercel Marketplace จะ inject ค่าเหล่านี้ให้อัตโนมัติเมื่อติดตั้ง Integration

# ── Supabase (via Vercel Marketplace) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Vercel Blob Storage (Storage → Blob → Enable) ──
BLOB_READ_WRITE_TOKEN=your-blob-read-write-token

# ── Upstash Redis (via Vercel Marketplace) ──
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Google Cloud API (OAuth2 — auto-create sheets, no manual setup) ──
# ใส่แค่ 3 ตัวนี้ ระบบจะสร้าง Sheet ขึ้นมาเอง
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxx

# ── หรือใช้ Service Account (manual setup) ──
# GOOGLE_SHEETS_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# ── App ──
NEXT_PUBLIC_APP_URL=https://doc-tracking-system.vercel.app
SUPER_ADMIN_EMAIL=store-hk@hillkoff.com